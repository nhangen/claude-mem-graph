{
  "description": "claude-mem-graph hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-context.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
